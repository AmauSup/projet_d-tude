{
  "name": "althea-project",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"frontend,backend\" --prefix-colors \"cyan,yellow\" \"npm run dev --workspace frontend\" \"npm run dev --workspace backend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "start:backend": "npm run start --workspace backend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}

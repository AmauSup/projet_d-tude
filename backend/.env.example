# Copiez ce fichier en .env et remplissez les valeurs
# IMPORTANT : Ne jamais committer .env dans git

# URL complète de connexion PostgreSQL (Neon ou autre)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clé secrète JWT — générez une valeur aléatoire forte (ex: openssl rand -hex 32)
JWT_SECRET=change-me-with-a-random-secret-64-chars

# Durée de validité du token JWT (ex: 1d, 7d, 2h)
JWT_EXPIRES=1d

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# Port du serveur backend
PORT=3001

# Environnement (development | production)
NODE_ENV=development
